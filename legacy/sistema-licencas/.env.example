# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_licencas
DB_USER=licencas_user
DB_PASSWORD=licencas123

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d
OFFLINE_TOKEN_SECRET=your_offline_token_secret_here

# RSA keys are REQUIRED for offline tokens (no fallback)
# Generate once and keep private key secret
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"
# Optional explicit JWT kid for offline tokens. If omitted, server derives from public key fingerprint.
# RSA_KEY_ID=rsa-prod-2026-01

# RSA Keys for Offline Token Signing (RS256)
# Generate with: npm run generate-rsa-keys
# IMPORTANT: Keep RSA_PRIVATE_KEY secret! Never commit to version control!
# RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE..."
# RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIj..."

# API Keys
API_KEY_SECRET=your_api_key_secret_here

# Encryption Keys
CACHE_ENCRYPTION_KEY=your_32_byte_encryption_key_here
CACHE_SIGNATURE_KEY=your_signature_key_here

# Security Settings
FINGERPRINT_MATCH_THRESHOLD=0.6
FINGERPRINT_V2_ENABLED=true
FINGERPRINT_V1_FALLBACK_UNTIL_UTC=2026-06-02T23:59:59Z
FINGERPRINT_RECONCILIATION_ENABLED=true
FINGERPRINT_RECONCILIATION_THRESHOLD=0.80
FINGERPRINT_RECONCILIATION_MIN_GAP=0.15
MAX_LOCATIONS_PER_DAY=3
MAX_FINGERPRINTS_PER_LICENSE=5
MAX_OFFLINE_DAYS=7

# Offline Validation Settings
OFFLINE_SOFT_CHECK_PERCENTAGE=0.5
MAX_OFFLINE_VALIDATIONS=100

# Rate Limiting
DEFAULT_RATE_LIMIT_WINDOW_MS=3600000
DEFAULT_RATE_LIMIT_MAX_REQUESTS=1000

# Cache Settings
CACHE_DEFAULT_TTL=3600
CACHE_LICENSE_TTL=3600
CACHE_FINGERPRINT_TTL=86400

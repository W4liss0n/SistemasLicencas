NODE_ENV=production
PORT=3001
API_PREFIX=/api/v2

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sistema_licencas_v2
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-at-least-32-characters
ACCESS_JWT_SECRET=change-me-access-jwt-secret-at-least-32-characters
REFRESH_JWT_SECRET=change-me-refresh-jwt-secret-at-least-32-characters
OFFLINE_JWT_PRIVATE_KEY_PEM=replace-with-rs256-private-key-pem-escaped
OFFLINE_JWT_PUBLIC_KEY_PEM=replace-with-rs256-public-key-pem-escaped
OFFLINE_JWT_KID=offline-key-v1
OFFLINE_MAX_HOURS=72
CLOCK_SKEW_SECONDS=120
REFRESH_TTL_DAYS=7
ACCESS_TTL_MINUTES=15
END_USER_AUTH_ENABLED=false
OIDC_ISSUER_URL=https://issuer.example.com
OIDC_CLIENT_ID=launcher-client
OIDC_SCOPES=openid profile email
OIDC_HTTP_TIMEOUT_MS=5000
OIDC_CLOCK_SKEW_SECONDS=120
AUTH_PASSWORD_PEPPER=change-me-auth-pepper-at-least-16-chars
REQUEST_TIMEOUT_MS=3000
IDEMPOTENCY_TTL_HOURS=24
LICENSE_ENGINE_STRATEGY=prisma
INTERNAL_ADMIN_API_KEYS=change-me-internal-admin-key

OTEL_ENABLED=false
OTEL_SERVICE_NAME=sistema-licencas-v2
METRICS_ENABLED=true
METRICS_PATH=/metrics

PUBLIC_DOMAIN=admin.example.com
BASIC_AUTH_REALM=Admin Backoffice v2
BASIC_AUTH_USER=admin
ADMIN_INTERNAL_API_KEY=change-me-internal-admin-key
ADMIN_WEB_ENABLE_MUTATIONS=false

CF_API_TOKEN=change-me-cloudflare-api-token
CF_ZONE_ID=change-me-cloudflare-zone-id
CF_RECORD_NAME=admin.example.com
TZ=America/Sao_Paulo

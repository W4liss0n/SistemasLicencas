{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/contract/prisma-license-engine\\.contract\\.spec\\.ts$",
  "setupFiles": ["<rootDir>/test/jest.setup.ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.json" }]
  },
  "testEnvironment": "node"
}

NODE_ENV=development
PORT=3001
API_PREFIX=/api/v2
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sistema_licencas_v2
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-at-least-32-chars-long
ACCESS_JWT_SECRET=change-me-access-jwt-secret-at-least-32-chars
REFRESH_JWT_SECRET=change-me-refresh-jwt-secret-at-least-32-chars
# Replace \\n with actual line breaks or keep escaped in .env files
OFFLINE_JWT_PRIVATE_KEY_PEM=
OFFLINE_JWT_PUBLIC_KEY_PEM=
OFFLINE_JWT_KID=offline-key-v1
OFFLINE_MAX_HOURS=72
CLOCK_SKEW_SECONDS=120
REFRESH_TTL_DAYS=7
ACCESS_TTL_MINUTES=15
END_USER_AUTH_ENABLED=false
END_USER_AUTH_AUTO_PROVISION=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_SCOPES=openid profile email
OIDC_HTTP_TIMEOUT_MS=5000
OIDC_CLOCK_SKEW_SECONDS=120
AUTH_PASSWORD_PEPPER=change-me-auth-pepper-at-least-16-chars
REQUEST_TIMEOUT_MS=3000
IDEMPOTENCY_TTL_HOURS=24
# auto: fake in test, prisma in development/production
LICENSE_ENGINE_STRATEGY=auto
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sistema-licencas-v2
# Optional, used when OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
METRICS_ENABLED=false
METRICS_PATH=/metrics

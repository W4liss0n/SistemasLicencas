{
    "name":  "sistema-licencas-v2",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Sistema de Licencas v2 (rewrite) com legado read-only",
    "type":  "commonjs",
    "scripts":  {
                    "build":  "tsc -p tsconfig.build.json",
                    "start":  "node dist/src/main.js",
                    "start:dev":  "ts-node src/main.ts",
                    "typecheck":  "tsc -p tsconfig.json --noEmit",
                    "test":  "jest --runInBand --detectOpenHandles",
                    "test:e2e":  "jest --config test/jest-e2e.json --runInBand",
                    "test:contract:fake":  "jest --runInBand --detectOpenHandles test/contract/fake-license-engine.contract.spec.ts",
                    "test:contract:prisma":  "npm run prisma:migrate:deploy \u0026\u0026 npm run prisma:seed \u0026\u0026 node -e \"process.env.RUN_PRISMA_CONTRACT=\u0027true\u0027; process.env.DATABASE_URL = process.env.DATABASE_URL || \u0027postgresql://postgres:postgres@localhost:5433/sistema_licencas_v2\u0027; require(\u0027child_process\u0027).execSync(\u0027npx jest --config test/jest-contract-prisma.json --runInBand --detectOpenHandles\u0027, { stdio: \u0027inherit\u0027 });\"",
                    "test:legacy":  "tsx test/legacy/compatibility.runner.ts",
                    "openapi:generate":  "npm run build \u0026\u0026 node dist/scripts/generate-openapi.js",
                    "openapi:validate":  "node scripts/validate-openapi.mjs",
                    "idempotency:cleanup":  "tsx scripts/idempotency-cleanup.ts",
                    "idempotency:cleanup:dry-run":  "tsx scripts/idempotency-cleanup.ts --dry-run",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate:dev":  "prisma migrate dev",
                    "prisma:migrate:deploy":  "prisma migrate deploy",
                    "prisma:seed":  "prisma db seed",
                    "prisma:studio":  "prisma studio",
                    "ci":  "npm run typecheck \u0026\u0026 npm run test \u0026\u0026 npm run openapi:generate \u0026\u0026 npm run openapi:validate"
                },
    "dependencies":  {
                         "@fastify/cors":  "^11.1.0",
                         "@fastify/helmet":  "^13.0.2",
                         "@fastify/rate-limit":  "^10.3.0",
                         "@nestjs/common":  "^11.0.12",
                         "@nestjs/config":  "^4.0.2",
                         "@nestjs/core":  "^11.0.12",
                         "@nestjs/jwt":  "^11.0.2",
                         "@nestjs/platform-fastify":  "^11.0.12",
                         "@nestjs/swagger":  "^11.2.0",
                         "@opentelemetry/api":  "^1.9.0",
                         "@opentelemetry/auto-instrumentations-node":  "^0.65.0",
                         "@opentelemetry/exporter-trace-otlp-http":  "^0.206.0",
                         "@opentelemetry/sdk-node":  "^0.206.0",
                         "@prisma/client":  "^6.4.1",
                         "class-transformer":  "^0.5.1",
                         "class-validator":  "^0.14.1",
                         "ioredis":  "^5.10.0",
                         "jose":  "^5.10.0",
                         "nestjs-pino":  "^4.4.1",
                         "pino":  "^9.6.0",
                         "pino-pretty":  "^13.0.0",
                         "prom-client":  "^15.1.3",
                         "reflect-metadata":  "^0.2.2",
                         "rxjs":  "^7.8.1",
                         "zod":  "^3.24.1"
                     },
    "prisma":  {
                   "seed":  "tsx prisma/seed.ts"
               },
    "devDependencies":  {
                            "@apidevtools/swagger-parser":  "^12.1.0",
                            "@nestjs/testing":  "^11.0.12",
                            "@types/jest":  "^29.5.14",
                            "@types/node":  "^22.13.4",
                            "@types/supertest":  "^6.0.2",
                            "jest":  "^29.7.0",
                            "prisma":  "^6.4.1",
                            "supertest":  "^7.0.0",
                            "ts-jest":  "^29.2.5",
                            "ts-node":  "^10.9.2",
                            "tsx":  "^4.19.3",
                            "typescript":  "^5.7.3"
                        }
}